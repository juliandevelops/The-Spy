    "This is the number of total players in your game, including the number of spies. It must be greater than 3, in order to not directly know who the spy is." : {
      "comment" : "A footer in the configuration sheet that explains the rule about the number of players in the game.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ist die Anzahl an Spielern in deinem Spiel, inklusive der Spione. Sie muss größer als 3 sein, damit niemand direkt weiß, wer der Spion ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este es el número total de jugadores en tu partida, incluyendo el número de espías. Debe ser mayor que 3, para que no se sepa directamente quién es el espía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il s'agit du nombre total de joueurs dans votre partie, y compris le nombre d'espions. Il doit être supérieur à 3 afin de ne pas savoir directement qui est l'espion."
          }
        }
      }
    },
