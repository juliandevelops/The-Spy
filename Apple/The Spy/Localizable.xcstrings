    "Your game must at least include 1 spy, and at least 1 player (with a complete total of 3 players)." : {
      "comment" : "A footer in the configuration sheet that explains the rules for the game.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Spiel muss mindestens einen Spion enthalten (mit einem minimum an Gesamtspielern von 3)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu partida debe incluir al menos 1 espía y al menos 1 jugador (con un total de 3 jugadores)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre partie doit comprendre au moins 1 espion et au moins 1 joueur (pour un total de 3 joueurs)."
          }
        }
      }
    }
